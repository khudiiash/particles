{
	"name": "gpu-particle-editor-monorepo",
	"version": "0.2.0",
	"private": true,
	"description": "WebGPU GPU particle editor, shared engine core, and three.js / PlayCanvas runtime players",
	"license": "MIT",
	"workspaces": [
		"packages/core",
		"packages/three",
		"packages/playcanvas",
		"packages/express",
		"apps/editor"
	],
	"scripts": {
		"dev": "npm run dev --workspace @khudiiash/particle-editor-app",
		"build": "npm run build --workspace @khudiiash/particles-core --workspace @khudiiash/particles-three --workspace @khudiiash/particles-playcanvas --workspace @khudiiash/particle-editor-app",
		"build:libs": "npm run build --workspace @khudiiash/particles-core --workspace @khudiiash/particles-three --workspace @khudiiash/particles-playcanvas",
		"build:editor": "npm run build --workspace @khudiiash/particle-editor-app",
		"start": "node packages/express/dev-server.js",
		"sync:render": "node scripts/sync-canonical-render.mjs",
		"sync:simulation": "node scripts/sync-canonical-simulation.mjs",
		"inject:noise": "node scripts/inject-particle-noise.mjs",
		"inject:shapes": "node scripts/inject-particle-shape-wgsl.mjs"
	},
	"engines": {
		"node": ">=18.17.0"
	},
	"devDependencies": {
		"esbuild": "^0.21.5",
		"vite": "^5.3.1"
	}
}
